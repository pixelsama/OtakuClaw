# Base URL for API calls (Gateway). Override in production with actual domain.
VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional WebSocket overrides. Defaults fall back to current origin + /ws/input/output.
# VITE_WS_BASE_URL=ws://127.0.0.1:8000
# VITE_WS_INPUT_PATH=ws/input
# VITE_WS_OUTPUT_PATH=ws/output

# Optional streaming endpoint override (default: chat/stream).
# VITE_STREAM_PATH=chat/stream
